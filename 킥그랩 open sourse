local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local plr = Players.LocalPlayer
local rs = ReplicatedStorage

-- 리모트 이벤트
local GrabEvents = rs:FindFirstChild("GrabEvents")
local SetNetworkOwner = GrabEvents and (GrabEvents:FindFirstChild("SetNetworkOwner") or GrabEvents:FindFirstChild("SetOwner"))
local DestroyGrabLine = GrabEvents and (GrabEvents:FindFirstChild("DestroyGrabLine") or GrabEvents:FindFirstChild("DestroyLine"))

-- =============================================
-- [ 변수 ]
-- =============================================
local kickActive = false
local kickThread = nil
local currentTarget = nil
local setOwnerCount = 0
local destroyCount = 0

-- =============================================
-- [ 현재 잡고 있는 상대 찾기 ]
-- =============================================
local function getGrabbedTarget()
    local myChar = plr.Character
    if not myChar then return nil end
    
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    local grabParts = workspace:FindFirstChild("GrabParts")
    if not grabParts then return nil end
    
    for _, grabPart in ipairs(grabParts:GetChildren()) do
        if grabPart.Name == "GrabPart" then
            local weld = grabPart:FindFirstChildOfClass("WeldConstraint")
            if weld and weld.Part1 then
                local targetPart = weld.Part1
                -- 이 파트가 어떤 플레이어의 것인지 확인
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= plr and player.Character then
                        if targetPart:IsDescendantOf(player.Character) then
                            return player
                        end
                    end
                end
            end
        end
    end
    
    return nil
end

-- =============================================
-- [ 킥그랩 실행 함수 (30/30 도배) ]
-- =============================================
local function startKickGrab()
    local target = getGrabbedTarget()
    
    if not target then
        Rayfield:Notify({
            Title = "❌ 오류",
            Content = "잡고 있는 상대가 없음",
            Duration = 2
        })
        return false
    end
    
    currentTarget = target
    kickActive = true
    
    Rayfield:Notify({
        Title = "🚀 킥그랩 시작",
        Content = "대상: " .. target.Name,
        Duration = 2
    })
    
    kickThread = task.spawn(function()
        while kickActive do
            -- 매 루프마다 현재 타겟 확인 (죽거나 사라지면 중지)
            if not currentTarget or not currentTarget.Character then
                break
            end
            
            local targetChar = currentTarget.Character
            local targetHrp = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso")
            local targetBody = targetChar:FindFirstChild("Torso") or targetChar:FindFirstChild("UpperTorso")
            local myChar = plr.Character
            
            if targetHrp and myChar and SetNetworkOwner and DestroyGrabLine then
                local myHrp = myChar:FindFirstChild("HumanoidRootPart")
                local cam = workspace.CurrentCamera
                
                if myHrp and cam then
                    -- 감금 위치 (카메라 앞)
                    local detentionPos = cam.CFrame * CFrame.new(0, 0, -19)
                    
                    -- ===== 30/30 도배 =====
                    -- SetOwner 30번
                    for i = 1, 30 do
                        pcall(function()
                            SetNetworkOwner:FireServer(targetHrp, detentionPos)
                            if targetBody then
                                SetNetworkOwner:FireServer(targetBody, detentionPos)
                            end
                        end)
                        setOwnerCount = setOwnerCount + 1
                    end
                    
                    -- 위치 고정
                    targetHrp.CFrame = detentionPos
                    targetHrp.AssemblyLinearVelocity = Vector3.zero
                    if targetBody then
                        targetBody.CFrame = detentionPos
                        targetBody.AssemblyLinearVelocity = Vector3.zero
                    end
                    
                    -- Destroy 30번
                    for i = 1, 30 do
                        pcall(function()
                            DestroyGrabLine:FireServer(targetHrp)
                            if targetBody then
                                DestroyGrabLine:FireServer(targetBody)
                            end
                        end)
                        destroyCount = destroyCount + 1
                    end
                end
            end
            
            RunService.RenderStepped:Wait()
        end
        
        -- 루프 종료 시 자동으로 상태 정리
        if kickActive then
            kickActive = false
            Rayfield:Notify({
                Title = "🛑 킥그랩 종료",
                Content = "대상 사라짐",
                Duration = 2
            })
        end
    end)
    
    return true
end

-- =============================================
-- [ 킥그랩 중지 함수 ]
-- =============================================
local function stopKickGrab()
    if kickActive then
        kickActive = false
        if kickThread then
            task.cancel(kickThread)
            kickThread = nil
        end
        Rayfield:Notify({
            Title = "🛑 킥그랩 중지",
            Content = string.format("SetOwner: %d | Destroy: %d", setOwnerCount, destroyCount),
            Duration = 2
        })
    else
        Rayfield:Notify({
            Title = "⚠️ 알림",
            Content = "실행 중이 아님",
            Duration = 1
        })
    end
end

-- =============================================
-- [ 현재 잡은 상대 표시 ]
-- =============================================
local function updateCurrentTarget()
    local target = getGrabbedTarget()
    if target then
        return "🎯 " .. target.Name .. " (" .. target.DisplayName .. ")"
    else
        return "❌ 잡은 상대 없음"
    end
end

